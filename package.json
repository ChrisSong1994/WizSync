{
  "name": "wizsync",
  "version": "1.0.5",
  "description": "Clean and professional directory sync app powered by Unison",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "npm run dev",
    "build": "tsc && vite build && electron-builder"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "electron-store": "^8.1.0",
    "lucide-react": "^0.363.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.2"
  },
  "build": {
    "appId": "com.wizsync.app",
    "productName": "WizSync",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "src/resources/bin/**/*"
    ],
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "src/resources/bin/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "public/assets/icon-512.png",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^29.1.6",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
